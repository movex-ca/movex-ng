<!DOCTYPE html>
<html lang="en">
<head>
    <!--
        FILE: dashboard/admin-dashboard.html
        PURPOSE:
        Admin dashboard shell layout for Movex Nigeria.

        HTML ONLY:
        This is the admin dashboard framework where internal admin pages
        will later open inside the main content area.

        NO FORM SUBMISSION HERE:
        This is a navigation and layout shell.
    -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Movex 9ja | Admin Dashboard</title>

    <!-- Favicon -->
    <link rel="icon" type="image/jpeg" href="../assets/images/movex-logo.jpg" />

    <!-- Shared dashboard stylesheet -->
    <link rel="stylesheet" href="../assets/css/dashboard.css" />
</head>
<body>
    <!-- Global toast/message placeholder area -->
    <div class="global-toast-area">
        <div class="toast-demo">
            <strong>Admin Notice</strong>
            <span>This reserved area can later display reusable system messages, approvals, warnings, and success notices.</span>
        </div>
    </div>

    <!-- Mobile overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="dashboard-layout">
        <!-- =====================================================
             LEFT SIDEBAR MENU
             Admin dashboard left navigation
             ===================================================== -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <img src="../assets/images/movex-logo.jpg" alt="Movex Logo" />
                <div class="brand-text">
                    <h1>MOVEX</h1>
                    <p>Admin Control Dashboard</p>
                    <span class="env-badge">9ja Demo</span>
                </div>
            </div>

            <div class="sidebar-profile">
                <div class="sidebar-profile-top">
                    <div class="profile-avatar">AD</div>
                    <div class="profile-meta">
                        <h2>System Admin</h2>
                        <p>Movex Operations</p>
                    </div>
                </div>
                <span class="role-badge">Admin Dashboard</span>
            </div>

            <div class="menu-group">
                <div class="menu-group-title">Overview</div>
                <ul class="menu-list">
                    <li class="menu-item active">
                        <a href="admin-dashboard.html">
                            <span class="menu-icon">🏠</span>
                            <span class="menu-text">
                                <strong>Dashboard</strong>
                                <span>Admin overview</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">📊</span>
                            <span class="menu-text">
                                <strong>Analytics</strong>
                                <span>Reports and insights</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">🔔</span>
                            <span class="menu-text">
                                <strong>Notifications</strong>
                                <span>System updates and alerts</span>
                            </span>
                        </a>
                    </li>
                </ul>
            </div>

            <div class="menu-group">
                <div class="menu-group-title">Accounts</div>
                <ul class="menu-list">
                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">👥</span>
                            <span class="menu-text">
                                <strong>Customers</strong>
                                <span>Manage customer accounts</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">🛵</span>
                            <span class="menu-text">
                                <strong>Drivers</strong>
                                <span>Manage driver accounts</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">🏢</span>
                            <span class="menu-text">
                                <strong>Business Partners</strong>
                                <span>Partner company accounts</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">🏬</span>
                            <span class="menu-text">
                                <strong>Company Clients</strong>
                                <span>Service-requesting companies</span>
                            </span>
                        </a>
                    </li>
                </ul>
            </div>

            <div class="menu-group">
                <div class="menu-group-title">Operations</div>
                <ul class="menu-list">
                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">📦</span>
                            <span class="menu-text">
                                <strong>Orders</strong>
                                <span>All logistics orders</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">🧭</span>
                            <span class="menu-text">
                                <strong>Pools</strong>
                                <span>Dispatch, truck, tanker and more</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">🛡</span>
                            <span class="menu-text">
                                <strong>Insurance</strong>
                                <span>Coverage settings and rules</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">📍</span>
                            <span class="menu-text">
                                <strong>Tracking</strong>
                                <span>Movement and delivery updates</span>
                            </span>
                        </a>
                    </li>
                </ul>
            </div>

            <div class="menu-group">
                <div class="menu-group-title">Approval Centre</div>
                <ul class="menu-list">
                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">✅</span>
                            <span class="menu-text">
                                <strong>Driver Approvals</strong>
                                <span>Review and activate drivers</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">📋</span>
                            <span class="menu-text">
                                <strong>Business Approvals</strong>
                                <span>Review partner businesses</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">🏢</span>
                            <span class="menu-text">
                                <strong>Company Approvals</strong>
                                <span>Review service companies</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">🎓</span>
                            <span class="menu-text">
                                <strong>Student Promo Approvals</strong>
                                <span>Review student requests</span>
                            </span>
                        </a>
                    </li>
                </ul>
            </div>

            <div class="menu-group">
                <div class="menu-group-title">Associations</div>
                <ul class="menu-list">
                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">🤝</span>
                            <span class="menu-text">
                                <strong>Associations</strong>
                                <span>Manage recognized groups</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">🚛</span>
                            <span class="menu-text">
                                <strong>Motor Garages</strong>
                                <span>Garage and code control</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">👤</span>
                            <span class="menu-text">
                                <strong>Tagged Members</strong>
                                <span>Association-linked drivers</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">₦</span>
                            <span class="menu-text">
                                <strong>Commissions</strong>
                                <span>Association payout logic</span>
                            </span>
                        </a>
                    </li>
                </ul>
            </div>

            <div class="menu-group">
                <div class="menu-group-title">System</div>
                <ul class="menu-list">
                    <li class="menu-item">
                        <a href="#">
                            <span class="menu-icon">⚙</span>
                            <span class="menu-text">
                                <strong>Settings</strong>
                                <span>Global platform controls</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="../terms.html">
                            <span class="menu-icon">📄</span>
                            <span class="menu-text">
                                <strong>Terms</strong>
                                <span>Terms page</span>
                            </span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="../privacy.html">
                            <span class="menu-icon">🔒</span>
                            <span class="menu-text">
                                <strong>Privacy</strong>
                                <span>Privacy page</span>
                            </span>
                        </a>
                    </li>
                </ul>
            </div>

            <div class="sidebar-footer">
                <ul class="menu-list">
                    <li class="menu-item">
                        <a href="../forms/auth/login.html">
                            <span class="menu-icon">↩</span>
                            <span class="menu-text">
                                <strong>Logout</strong>
                                <span>Return to login</span>
                            </span>
                        </a>
                    </li>
                </ul>
            </div>
        </aside>

        <!-- =====================================================
             RIGHT MAIN DASHBOARD AREA
             ===================================================== -->
        <main class="dashboard-main">
            <header class="dashboard-header">
                <div class="header-row">
                    <div class="header-left">
                        <button class="menu-toggle" data-menu-open aria-label="Open menu">☰</button>
                        <div class="page-heading">
                            <h1>Admin Dashboard</h1>
                            <p>Control operations, approvals, accounts, pools, and system setup.</p>
                        </div>
                    </div>

                    <div class="header-right">
                        <span class="header-chip">Admin / Nigeria</span>
                        <a href="#" class="header-button">New Admin Action</a>
                    </div>
                </div>
            </header>

            <section class="dashboard-content">
                <div class="content-stack">
                    <!-- Hero welcome panel -->
                    <div class="hero-card">
                        <h2>Movex Admin Control Centre</h2>
                        <p>
                            This dashboard is the main shell for all admin pages. Driver approvals,
                            business partner management, pool setup, associations, commission handling,
                            reports, and system settings can later open inside this admin workspace.
                        </p>
                        <div class="hero-actions">
                            <a href="#" class="btn-primary">Open Approval Centre</a>
                            <a href="#" class="btn-secondary">Manage Pools</a>
                        </div>
                    </div>

                    <!-- Admin summary cards -->
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-top">
                                <span class="stat-label">Pending Driver Approvals</span>
                                <span class="stat-icon">✅</span>
                            </div>
                            <div class="stat-value">18</div>
                            <div class="stat-note">Drivers awaiting review</div>
                        </div>

                        <div class="stat-card">
                            <div class="stat-top">
                                <span class="stat-label">Active Orders</span>
                                <span class="stat-icon">📦</span>
                            </div>
                            <div class="stat-value">142</div>
                            <div class="stat-note">Orders currently in motion</div>
                        </div>

                        <div class="stat-card">
                            <div class="stat-top">
                                <span class="stat-label">Registered Drivers</span>
                                <span class="stat-icon">🛵</span>
                            </div>
                            <div class="stat-value">356</div>
                            <div class="stat-note">Across all pools and locations</div>
                        </div>

                        <div class="stat-card">
                            <div class="stat-top">
                                <span class="stat-label">Associations</span>
                                <span class="stat-icon">🤝</span>
                            </div>
                            <div class="stat-value">22</div>
                            <div class="stat-note">Recognized association records</div>
                        </div>
                    </div>

                    <!-- Admin quick actions -->
                    <div class="panel-card">
                        <div class="panel-header">
                            <div>
                                <h3>Admin Quick Actions</h3>
                                <p>Fast access to common admin pages and approval flows.</p>
                            </div>
                            <a href="#" class="panel-link">View full menu</a>
                        </div>

                        <div class="quick-grid">
                            <a href="#" class="quick-card">
                                <h4>Driver Approvals</h4>
                                <p>Review new driver registrations, documents, pools, and statuses.</p>
                            </a>

                            <a href="#" class="quick-card">
                                <h4>Manage Pools</h4>
                                <p>Update transport pool categories such as Ajeigboro, tanker, and frozen foods.</p>
                            </a>

                            <a href="#" class="quick-card">
                                <h4>Company Requests</h4>
                                <p>Review corporate accounts requesting service access and promo consideration.</p>
                            </a>

                            <a href="#" class="quick-card">
                                <h4>Association Tagging</h4>
                                <p>Assign drivers to recognized associations and motor garage structures.</p>
                            </a>

                            <a href="#" class="quick-card">
                                <h4>Student Promo Review</h4>
                                <p>Approve or reject student verification submissions and related discounts.</p>
                            </a>

                            <a href="#" class="quick-card">
                                <h4>Finance & Reports</h4>
                                <p>Open payment, payout, wallet, and commission overview pages.</p>
                            </a>
                        </div>
                    </div>

                    <!-- Recent operations -->
                    <div class="panel-card">
                        <div class="panel-header">
                            <div>
                                <h3>Recent Admin Activity</h3>
                                <p>Example activity stream showing what can later be replaced by live records.</p>
                            </div>
                            <a href="#" class="panel-link">See activity log</a>
                        </div>

                        <div class="activity-list">
                            <div class="activity-item">
                                <div class="activity-badge">✅</div>
                                <div class="activity-text">
                                    <h4>Driver Approved</h4>
                                    <p>A newly registered driver was reviewed and moved to active status.</p>
                                    <div class="activity-time">Today, 9:40 AM</div>
                                </div>
                            </div>

                            <div class="activity-item">
                                <div class="activity-badge">🤝</div>
                                <div class="activity-text">
                                    <h4>Association Member Tagged</h4>
                                    <p>A driver was linked to a recognized association and motor garage record.</p>
                                    <div class="activity-time">Today, 8:15 AM</div>
                                </div>
                            </div>

                            <div class="activity-item">
                                <div class="activity-badge">🎓</div>
                                <div class="activity-text">
                                    <h4>Student Promo Reviewed</h4>
                                    <p>An uploaded student ID request was reviewed for eligibility and account tagging.</p>
                                    <div class="activity-time">Yesterday, 5:30 PM</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Admin display area -->
                    <div class="panel-card">
                        <div class="panel-header">
                            <div>
                                <h3>Admin Content Display Area</h3>
                                <p>This is the main area where all admin pages will later open inside the dashboard.</p>
                            </div>
                        </div>

                        <p style="font-size: 14px; line-height: 1.8; color: #667085;">
                            Future admin pages that can load here include customers, drivers, business partners,
                            company clients, orders, pools, pricing, insurance, association codes, motor garages,
                            finance reports, settings, and approval workflow pages.
                        </p>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="../assets/js/dashboard.js"></script>
</body>
</html>